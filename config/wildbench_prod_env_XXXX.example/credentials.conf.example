# OpenAI-compatible credentials used by HELM's `OpenAIClient`.
#
# Default: NVIDIA Integrate + `openai/gpt-oss-120b` (set your nvapi key below).
# If you prefer OpenAI or HF Router, change `openaiBaseUrl` + `wildbenchJudgeOpenAIModelName`.
openaiBaseUrl: https://integrate.api.nvidia.com/v1
wildbenchJudgeOpenAIModelName: openai/gpt-oss-120b
openaiApiKey: <xxxxx>

# Alternative: HF Router
# openaiBaseUrl: https://router.huggingface.co/v1
# wildbenchJudgeOpenAIModelName: openai/gpt-oss-120b:fastest
# openaiApiKey: <YOUR-HF_TOKEN-HERE>

# Alternative: OpenAI
# openaiBaseUrl: https://api.openai.com/v1
# wildbenchJudgeOpenAIModelName: gpt-4o-2024-05-13
# openaiApiKey: <YOUR-OPENAI-KEY-HERE>
